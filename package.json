{
  "name": "scribely",
  "version": "0.1.0",
  "description": "Scribely — a desktop app that records your meetings locally (no bot joins the call), transcribes them, and generates structured notes.",
  "main": "src/index.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/danishdotdev/Scribely.git"
  },
  "keywords": [
    "meeting-notes",
    "transcription",
    "speaker-diarization",
    "electron",
    "desktop-recorder",
    "local-capture",
    "notes"
  ],
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "check": "node scripts/check-syntax.js",
    "test": "node scripts/run-tests.js",
    "desktop:install": "npm --prefix desktop install",
    "desktop:dev": "npm --prefix desktop run dev"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@indic-transliteration/sanscript": "^1.3.3",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "form-data": "^4.0.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
