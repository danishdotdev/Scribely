NODE_ENV=development
PORT=3000

# Optional bearer token protecting the local API. Leave blank for local desktop
# use (the desktop app talks to http://127.0.0.1:3000).
API_KEY=

# Where recordings and the session store live.
LOCAL_CAPTURE_DIR=./data/local-captures
MEETING_STORE_PATH=./data/meetings.json

# Transcription. Desktop users can paste a provider key directly in the app's
# Settings; these env keys are optional server-side fallbacks.
TRANSCRIPTION_PROVIDER=assemblyai
ASSEMBLYAI_API_KEY=
DEEPGRAM_API_KEY=
OPENAI_API_KEY=

# Optional VibeVoice local ASR (no API key; needs Python + transformers + a GPU).
VIBEVOICE_ENABLED=false
VIBEVOICE_PYTHON=python
VIBEVOICE_ASR_MODEL=microsoft/VibeVoice-ASR-HF
VIBEVOICE_ASR_SCRIPT=./scripts/vibevoice-asr-transcribe.py
VIBEVOICE_ASR_TIMEOUT_MS=7200000
VIBEVOICE_ASR_MAX_NEW_TOKENS=4096

# Transcription tuning (optional).
MEETING_AAI_MODELS=universal-3-5-pro,universal-2
MEETING_LANG_CODES=
MEETING_LANG_CODE=
MEETING_WORD_BOOST=
MEETING_SPEAKERS_EXPECTED=
MEETING_AAI_PROMPT=
MEETING_CODE_SWITCHING_CONFIDENCE=
